# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=supply_chain
POSTGRES_USER=datauser
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql://datauser:changeme@localhost:5432/supply_chain

# Airflow
AIRFLOW__CORE__FERNET_KEY=your_fernet_key_here
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://datauser:changeme@postgres:5432/airflow

# dbt
DBT_PROFILES_DIR=./dbt
DBT_TARGET=dev

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=supply_chain_models

# Data paths
RAW_DATA_DIR=/data/raw
